---
interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'Galaxy Protocol',
  subtitle = 'DYSON SWARM & TARDIS MATRIX // ACTIVE',
} = Astro.props;
---

<div class="glass-panel pointer-events-auto inline-flex max-w-full flex-col gap-1 px-6 py-4">
  <h1 class="text-balance text-2xl font-bold uppercase tracking-[0.28em] text-[var(--accent-cyan)] sm:text-3xl">
    {title}
  </h1>
  <p class="text-[10px] font-mono uppercase tracking-[0.34em] text-[var(--accent-orange)] sm:text-xs">
    {subtitle}
  </p>
</div>
