# Server-side AI config used by /api/agent
AI_PROVIDER=cloudflare
AI_MODEL=@cf/zai-org/glm-4.7-flash
AI_API_KEY=your_provider_api_key_here
AI_ACCOUNT_ID=your_cloudflare_account_id_here

# Compatibility fallbacks
GOOGLE_GENERATIVE_AI_API_KEY=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

PUBLIC_SUPABASE_URL=your_supabase_project_url_here
PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-only Supabase access for assistant observability and retrieval
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
EMBEDDING_MODEL=your_provider_embedding_model_here
EMBEDDING_DIMENSIONS=1536

# On-demand remote integration test config
TARGET_AGENT_API_URL=http://127.0.0.1:4321
ASSISTANT_EVENTS_TEST_TIMEOUT_MS=12000
ASSISTANT_EVENTS_REQUEST_TIMEOUT_MS=8000
